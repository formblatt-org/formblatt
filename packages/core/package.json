{
  "name": "@formblatt/core",
  "version": "0.1.0",
  "description": "Framework-agnostic core of formblatt: JSON form definitions to Valibot schemas, condition/expression evaluation, layout resolution, migrations.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/formblatt-org/formblatt.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/formblatt-org/formblatt#readme",
  "bugs": "https://github.com/formblatt-org/formblatt/issues",
  "keywords": [
    "form",
    "forms",
    "schema",
    "json",
    "form-builder",
    "validation",
    "valibot"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "unbuild",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "size": "size-limit"
  },
  "size-limit": [
    { "path": "dist/index.mjs", "limit": "13 kB" }
  ],
  "peerDependencies": {
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@size-limit/file": "^12.1.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "size-limit": "^13.0.1",
    "unbuild": "^3.6.1",
    "valibot": "^1.4.2",
    "vitest": "^4.1.10"
  }
}
