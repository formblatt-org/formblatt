{
  "name": "@formblatt/vue",
  "version": "0.1.0",
  "description": "Vue bindings for formblatt: composables and headless components over @formisch/vue.",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./style.css": "./dist/style.css"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@formblatt/core": "workspace:*"
  },
  "peerDependencies": {
    "@formisch/vue": "^1.0.0-rc.0",
    "valibot": "^1.4.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@formisch/vue": "1.0.0-rc.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "typescript": "^5.9.3",
    "valibot": "^1.4.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.7"
  }
}
