{
  "name": "@formblatt/vue",
  "version": "0.1.0",
  "description": "Vue bindings for formblatt: composables and headless components over @formisch/vue.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/formblatt-org/formblatt.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/formblatt-org/formblatt#readme",
  "bugs": "https://github.com/formblatt-org/formblatt/issues",
  "keywords": [
    "form",
    "forms",
    "vue",
    "schema",
    "json",
    "form-builder",
    "validation",
    "formisch",
    "valibot"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./style.css": "./dist/style.css"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "size": "size-limit"
  },
  "size-limit": [
    { "path": "dist/index.mjs", "limit": "12 kB" },
    { "path": "dist/style.css", "limit": "2.5 kB" }
  ],
  "dependencies": {
    "@formblatt/core": "workspace:*"
  },
  "peerDependencies": {
    "@formisch/vue": "1.0.0-rc.0",
    "valibot": "^1.4.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@formisch/vue": "1.0.0-rc.0",
    "@size-limit/file": "^12.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "size-limit": "^12.1.0",
    "valibot": "^1.4.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue": "^3.5.40",
    "vue-tsc": "^3.3.7"
  }
}
